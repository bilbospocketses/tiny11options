    { "id": "tweak-prevent-teams-install", "category": "communication", "displayName": "Prevent Microsoft Teams from being installed", "description": "Sets HKLM\\SOFTWARE\\Policies\\Microsoft\\Teams!DisableInstallation=1.", "default": "apply", "runtimeDepsOn": [], "actions": [ { "type": "registry", "op": "set", "hive": "SOFTWARE", "key": "Policies\\Microsoft\\Teams", "name": "DisableInstallation", "valueType": "REG_DWORD", "value": "1" } ] },
    { "id": "tweak-prevent-new-outlook", "category": "communication", "displayName": "Prevent installation of New Outlook", "description": "Sets HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\Windows Mail!PreventRun=1.", "default": "apply", "runtimeDepsOn": [], "actions": [ { "type": "registry", "op": "set", "hive": "SOFTWARE", "key": "Policies\\Microsoft\\Windows\\Windows Mail", "name": "PreventRun", "valueType": "REG_DWORD", "value": "1" } ] },
    { "id": "tweak-prevent-outlook-update", "category": "communication", "displayName": "Block scheduled OutlookUpdate orchestrator", "description": "Marks the OutlookUpdate scheduled-update tasks as completed and removes the OOBE OutlookUpdate orchestrator key.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "registry", "op": "set", "hive": "SOFTWARE", "key": "Microsoft\\Windows\\CurrentVersion\\WindowsUpdate\\Orchestrator\\UScheduler_Oobe\\OutlookUpdate", "name": "workCompleted", "valueType": "REG_DWORD", "value": "1" },
      { "type": "registry", "op": "set", "hive": "SOFTWARE", "key": "Microsoft\\Windows\\CurrentVersion\\WindowsUpdate\\Orchestrator\\UScheduler\\OutlookUpdate", "name": "workCompleted", "valueType": "REG_DWORD", "value": "1" },
      { "type": "registry", "op": "remove", "hive": "SOFTWARE", "key": "Microsoft\\WindowsUpdate\\Orchestrator\\UScheduler_Oobe\\OutlookUpdate" }
    ] },
    { "id": "tweak-prevent-devhome-update", "category": "communication", "displayName": "Block scheduled DevHomeUpdate orchestrator", "description": "Marks the DevHomeUpdate scheduled-update task as completed and removes the OOBE DevHomeUpdate orchestrator key.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "registry", "op": "set", "hive": "SOFTWARE", "key": "Microsoft\\Windows\\CurrentVersion\\WindowsUpdate\\Orchestrator\\UScheduler\\DevHomeUpdate", "name": "workCompleted", "valueType": "REG_DWORD", "value": "1" },
      { "type": "registry", "op": "remove", "hive": "SOFTWARE", "key": "Microsoft\\WindowsUpdate\\Orchestrator\\UScheduler_Oobe\\DevHomeUpdate" }
    ] },

    { "id": "remove-edge", "category": "edge-and-webview", "displayName": "Microsoft Edge (browser folders)", "description": "Removes Program Files (x86)\\Microsoft\\Edge, EdgeUpdate, and EdgeCore directories.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "filesystem", "op": "remove", "path": "Program Files (x86)\\Microsoft\\Edge", "recurse": true },
      { "type": "filesystem", "op": "remove", "path": "Program Files (x86)\\Microsoft\\EdgeUpdate", "recurse": true },
      { "type": "filesystem", "op": "remove", "path": "Program Files (x86)\\Microsoft\\EdgeCore", "recurse": true }
    ] },
    { "id": "remove-edge-webview", "category": "edge-and-webview", "displayName": "Microsoft Edge System32 WebView host", "description": "Takes ownership of and removes the Windows\\System32\\Microsoft-Edge-Webview directory. NOTE: This is a separate System32 binary, NOT the WebView2 Runtime that powers Start menu search and Widgets — that Runtime lives elsewhere and is preserved.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "filesystem", "op": "takeown-and-remove", "path": "Windows\\System32\\Microsoft-Edge-Webview", "recurse": true }
    ] },
    { "id": "tweak-remove-edge-uninstall-keys", "category": "edge-and-webview", "displayName": "Remove Edge uninstall registry entries", "description": "Removes the WOW6432Node Uninstall keys for Microsoft Edge and Microsoft Edge Update.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "registry", "op": "remove", "hive": "SOFTWARE", "key": "WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Microsoft Edge" },
      { "type": "registry", "op": "remove", "hive": "SOFTWARE", "key": "WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Microsoft Edge Update" }
    ] },

    { "id": "remove-onedrive-setup", "category": "onedrive", "displayName": "OneDrive setup binary", "description": "Takes ownership of and removes Windows\\System32\\OneDriveSetup.exe so OneDrive does not auto-install on first sign-in.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "filesystem", "op": "takeown-and-remove", "path": "Windows\\System32\\OneDriveSetup.exe", "recurse": false }
    ] },
    { "id": "tweak-disable-onedrive-folder-backup", "category": "onedrive", "displayName": "Disable OneDrive folder backup (DisableFileSyncNGSC)", "description": "Sets HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\OneDrive!DisableFileSyncNGSC=1.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "registry", "op": "set", "hive": "SOFTWARE", "key": "Policies\\Microsoft\\Windows\\OneDrive", "name": "DisableFileSyncNGSC", "valueType": "REG_DWORD", "value": "1" }
    ] },

    { "id": "tweak-disable-telemetry", "category": "telemetry", "displayName": "Disable diagnostic data and input personalization", "description": "Disables advertising ID, tailored experiences, online speech privacy, input personalization, and the AllowTelemetry policy. Also stops dmwappushservice.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "registry", "op": "set", "hive": "NTUSER",   "key": "Software\\Microsoft\\Windows\\CurrentVersion\\AdvertisingInfo", "name": "Enabled", "valueType": "REG_DWORD", "value": "0" },
      { "type": "registry", "op": "set", "hive": "NTUSER",   "key": "Software\\Microsoft\\Windows\\CurrentVersion\\Privacy", "name": "TailoredExperiencesWithDiagnosticDataEnabled", "valueType": "REG_DWORD", "value": "0" },
      { "type": "registry", "op": "set", "hive": "NTUSER",   "key": "Software\\Microsoft\\Speech_OneCore\\Settings\\OnlineSpeechPrivacy", "name": "HasAccepted", "valueType": "REG_DWORD", "value": "0" },
      { "type": "registry", "op": "set", "hive": "NTUSER",   "key": "Software\\Microsoft\\Input\\TIPC", "name": "Enabled", "valueType": "REG_DWORD", "value": "0" },
      { "type": "registry", "op": "set", "hive": "NTUSER",   "key": "Software\\Microsoft\\InputPersonalization", "name": "RestrictImplicitInkCollection", "valueType": "REG_DWORD", "value": "1" },
      { "type": "registry", "op": "set", "hive": "NTUSER",   "key": "Software\\Microsoft\\InputPersonalization", "name": "RestrictImplicitTextCollection", "valueType": "REG_DWORD", "value": "1" },
      { "type": "registry", "op": "set", "hive": "NTUSER",   "key": "Software\\Microsoft\\InputPersonalization\\TrainedDataStore", "name": "HarvestContacts", "valueType": "REG_DWORD", "value": "0" },
      { "type": "registry", "op": "set", "hive": "NTUSER",   "key": "Software\\Microsoft\\Personalization\\Settings", "name": "AcceptedPrivacyPolicy", "valueType": "REG_DWORD", "value": "0" },
      { "type": "registry", "op": "set", "hive": "SOFTWARE", "key": "Policies\\Microsoft\\Windows\\DataCollection", "name": "AllowTelemetry", "valueType": "REG_DWORD", "value": "0" },
      { "type": "registry", "op": "set", "hive": "SYSTEM",   "key": "ControlSet001\\Services\\dmwappushservice", "name": "Start", "valueType": "REG_DWORD", "value": "4" }
    ] },
    { "id": "disable-task-compat-appraiser", "category": "telemetry", "displayName": "Remove Microsoft Compatibility Appraiser scheduled task", "description": "Deletes the Microsoft\\Windows\\Application Experience\\Microsoft Compatibility Appraiser task definition file.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "scheduled-task", "op": "remove", "path": "Microsoft\\Windows\\Application Experience\\Microsoft Compatibility Appraiser", "recurse": false }
    ] },
    { "id": "disable-task-ceip", "category": "telemetry", "displayName": "Remove Customer Experience Improvement Program tasks", "description": "Recursively deletes the Microsoft\\Windows\\Customer Experience Improvement Program task folder.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "scheduled-task", "op": "remove", "path": "Microsoft\\Windows\\Customer Experience Improvement Program", "recurse": true }
    ] },
    { "id": "disable-task-program-data-updater", "category": "telemetry", "displayName": "Remove Program Data Updater scheduled task", "description": "Deletes the Microsoft\\Windows\\Application Experience\\ProgramDataUpdater task definition file.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "scheduled-task", "op": "remove", "path": "Microsoft\\Windows\\Application Experience\\ProgramDataUpdater", "recurse": false }
    ] },
    { "id": "disable-task-chkdsk-proxy", "category": "telemetry", "displayName": "Remove Chkdsk Proxy scheduled task", "description": "Deletes the Microsoft\\Windows\\Chkdsk\\Proxy task definition file.", "default": "apply", "runtimeDepsOn": [], "actions": [
      { "type": "scheduled-task", "op": "remove", "path": "Microsoft\\Windows\\Chkdsk\\Proxy", "recurse": false }
