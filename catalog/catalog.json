    { "id": "disable-task-werqueue", "category": "telemetry", "displayName": "Remove Windows Error Reporting QueueReporting task", "description": "Deletes the Microsoft\\Windows\\Windows Error Reporting\\QueueReporting task definition file.", "default": "apply", "runtimeDepsOn": [], "actions": [
